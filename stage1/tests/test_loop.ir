// expect: 55
func @main() -> i64 {
entry:
  br @loop
loop:
  %i = phi i64 [1, @entry], [%i_next, @loop]
  %sum = phi i64 [0, @entry], [%sum_next, @loop]
  %sum_next = add i64 %sum, %i
  %i_next = add i64 %i, 1
  %done = cmp_ge i64 %i_next, 11
  br_cond %done, @exit, @loop
exit:
  ret i64 %sum_next
}
