// expect: 234
fn collatz_steps(n: i64) -> i64 {
    let steps: i64 = 0
    while n != 1 {
        if n % 2 == 0 {
            n = n / 2
        } else {
            n = n * 3 + 1
        }
        steps = steps + 1
    }
    return steps
}

fn main() -> i64 {
    let total: i64 = 0
    let i: i64 = 1
    while i <= 200000 {
        total = total + collatz_steps(i)
        i = i + 1
    }
    return total % 256
}
