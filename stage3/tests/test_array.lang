// expect: 55
extern fn malloc(i64) -> *i8
extern fn free(*i8)

fn main() -> i64 {
    let buf: *i8 = malloc(80)
    let arr: *i64 = buf as *i64
    let i: i64 = 0
    while i < 10 {
        let p: *i64 = (arr as i64 + i * 8) as *i64
        *p = i + 1
        i = i + 1
    }
    let sum: i64 = 0
    i = 0
    while i < 10 {
        let p: *i64 = (arr as i64 + i * 8) as *i64
        sum = sum + *p
        i = i + 1
    }
    free(buf)
    return sum
}
